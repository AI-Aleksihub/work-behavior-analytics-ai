# InfluxDB settings
INFLUXDB_ENABLED=true
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_USERNAME=FIXME
INFLUXDB_PASSWORD=FIXME
INFLUXDB_ORG=FIXME
INFLUXDB_BUCKET=FIXME
INFLUXDB_ADMIN_TOKEN=FIXME

# Elasticsearch settings
# Note: ELASTIC_USERNAME is not required by default because xpack.security.enabled=false disables authentication in the default Docker image. If you enable security, add both ELASTIC_USERNAME and ELASTIC_PASSWORD.
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTIC_PASSWORD=FIXME
# Postgres setting. For local docker container, you may use the suggested values.
# POSTGRES_USER=postgres
POSTGRES_USER=FIXME
# POSTGRES_PASSWORD=postgres
POSTGRES_PASSWORD=FIXME
# POSTGRES_DB=postgres
POSTGRES_DB=FIXME
# For local development (PostgreSQL in Docker, app running locally)
DATABASE_URL=postgresql+asyncpg://FIXME_USERNAME:FIXME_PASSWORD@localhost:5432/FIXME
# For Docker Compose (both app and PostgreSQL in Docker)
# DATABASE_URL=postgresql+asyncpg://FIXME_USERNAME:FIXME_PASSWORD@postgres:5432/FIXME

# RabbitMQ Settings
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/

# Connector settings
# Connector encryption (Fernet key)
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_ENCRYPTION_KEY=FIXME

# Set to True if if using a custom LLM provider which cannot be used with Langchain's provider-native Neo4j pipeline
FF_NEO4J_USE_PROVIDER_PIPELINE=False

# LLM Provider Selection (openai, custom)
LLM_PROVIDER=openai

# OpenAI API configuration for AI agent
OPENAI_API_KEY=FIXME
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Custom provider configuration (for in-house LLM)
CUSTOM_API_TOKEN=FIXME
CUSTOM_API_URL=https://api.example.com/chat

# LLM Model (used by both OpenAI and Custom providers)
LLM_MODEL=gpt-5  

# Token management
MAX_TOKENS=16000

#Timeouts
HTTP_REQUEST_TIMEOUT=60
NEO4J_QUERY_TIMEOUT=10

# Graph UI Configuration
GRAPH_UI_MAX_NODES_TO_EXPAND=20
GRAPH_UI_MAX_NODE_LABEL_CHARS=10

# Timezone. Eg: UTC, America/Los_Angeles,Asia/Kolkata
TIMEZONE=UTC

# UI Configuration (Default: "Mar 15, 2026 10:00 AM")
UI_DATETIME_FORMAT="%b %d, %Y %I:%M %p"

LOG_FORMAT=text
LOG_LEVEL=DEBUG
ENABLE_FILE_LOGGING=1
LOG_DIR=./logs

PYTHONPATH=<workspace_path>

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=FIXME
NEO4J_PASSWORD=FIXME
NEO4J_ENABLED=true
NEO4J_MODE=chain

# Settings for jira and github sync
# API server to get configuration from
API_SERVER=http://app:8000/
# Setting for config source. Possible values SERVER or FILE
CONFIGURATION_SOURCE=SERVER


# Test environment
RUN_COLLAB_DB_VALIDATION=1

# MCP servers.
# Token should have read access to the relevant repos and orgs in github.
# Change 
GITHUB_MCP_SERVER_URL=http://github-mcp:8082/mcp
# Use this for local development when MCP server is running locally or debugging from IDE
#GITHUB_MCP_SERVER_URL=http://localhost:8082/mcp
GITHUB_MCP_ENABLED=true
GITHUB_MCP_TOKEN=FIXME

# Atlassian (Jira + Confluence) MCP Server
# The Atlassian Rovo MCP Server is cloud-hosted — no Docker service is needed.
# Endpoint: https://mcp.atlassian.com/v1/mcp
#
# Prerequisites before enabling:
#   1. An Atlassian org admin must enable API token authentication for Rovo MCP:
#      Atlassian Administration → Security → Atlassian Rovo MCP Server → Configure authentication → Enable API token auth
#      Docs: https://support.atlassian.com/atlassian-rovo-mcp-server/docs/configuring-authentication-via-api-token/
#   2. Generate a Rovo MCP scoped API token (NOT a standard Jira API token):
#      https://id.atlassian.com/manage-profile/security/api-tokens
#      Select scope: Rovo MCP Server
#
# Note: Only Atlassian Cloud is supported. Jira Server and Data Center are not.
ATLASSIAN_MCP_ENABLED=false
ATLASSIAN_MCP_SERVER_URL=https://mcp.atlassian.com/v1/mcp
ATLASSIAN_MCP_TOKEN=FIXME

# Connector settings
GITHUB_TOKEN_FOR_PUBLIC_REPOS=fixme

COMMIT_DAYS_LIMIT=60
PULL_REQUEST_DAYS_LIMIT=60
IDENTITY_REFRESH_DAYS=7
MAX_TEAM_SIZE=100

JIRA_LOOKBACK_DAYS=90
JIRA_MAX_RESULTS_PER_PAGE=100

# Jira Field Configuration
# Customize these if your Jira instance uses different field names
JIRA_EPIC_TEAM_FIELD=Team
JIRA_ISSUE_TEAM_FIELD=Team
JIRA_EPIC_START_DATE_FIELD=created
JIRA_EPIC_DUE_DATE_FIELD=duedate

# Python Path
# For local development: set to <workspace full path>/app
# For Docker: /app (set automatically in via Dockerfile)
PYTHONPATH=<workspace full path>:/<workspace full path>/connectors

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=JSON
ENABLE_FILE_LOGGING=1
LOG_DIR=logs
LOG_SIGNAL_DUMPS=0


# For neo4j_queries/test_catalog_queries.py get some valid values from neo4j.
# look for person nodes and use their ids (value of id not the system generated ID, <elementId> or <id>) for the following variables.
PERSON1_ID=person_<FIXME>
PERSON2_ID=person_<FIXME>
CONDITION_NODE_ID=person_<FIXME>
